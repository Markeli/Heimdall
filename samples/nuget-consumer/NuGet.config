<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<clear />
		<add key="heimdall" value="http://localhost:8080/nuget/relaxed/v3/index.json"
			protocolVersion="3" allowInsecureConnections="true" />
	</packageSources>
	<packageSourceMapping>
		<packageSource key="heimdall">
			<package pattern="*" />
		</packageSource>
	</packageSourceMapping>
</configuration>
